<nav id="nav">
  <a class="nav-logo" href="{{ routes.root_url }}">
    {%- if section.settings.logo != blank -%}
      <img src="{{ section.settings.logo | img_url: '240x' }}" alt="{{ shop.name }}" height="48" style="width:auto;">
    {%- else -%}
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" height="48" style="width:auto;">
    {%- endif -%}
  </a>

  <ul class="nav-links" id="nav-links">
    <li><a href="{{ routes.root_url }}" {% if template == 'index' %}class="active"{% endif %}>Home</a></li>
    <li><a href="{{ pages['about'].url }}" {% if page.handle == 'about' %}class="active"{% endif %}>About</a></li>
    <li><a href="{{ routes.all_products_collection_url }}" {% if template contains 'collection' %}class="active"{% endif %}>Shop</a></li>
    <li><a href="{{ pages['size-chart'].url }}" {% if page.handle == 'size-chart' %}class="active"{% endif %}>Size Chart</a></li>
    <li><a href="{{ pages['contact'].url }}" {% if page.handle == 'contact' %}class="active"{% endif %}>Contact</a></li>
  </ul>

  <div class="nav-actions">
    <button class="nav-icon-btn" id="search-open" aria-label="Search" title="Search">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>
    {%- if customer -%}
      <a href="{{ routes.account_url }}" class="nav-icon-btn" title="My Account">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
    {%- else -%}
      <a href="{{ routes.account_login_url }}" class="nav-icon-btn" title="Sign In">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
    {%- endif -%}
    <a class="nav-cart" href="{{ routes.cart_url }}" title="Cart">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      <span class="cart-badge" id="cart-badge">{{ cart.item_count }}</span>
    </a>
    <a class="btn-nav" href="{{ routes.all_products_collection_url }}">Shop Now</a>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}
