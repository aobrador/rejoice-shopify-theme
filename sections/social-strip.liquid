<div class="section social-section">
  <div class="section-title fade-in" style="margin-bottom:36px;">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h2>{{ section.settings.heading }}</h2>
    <div class="divider-purple"></div>
    {%- if section.settings.subtext != blank -%}
      <p>{{ section.settings.subtext }}</p>
    {%- endif -%}
  </div>

  <div class="social-icons-row fade-in">
    {%- if section.settings.facebook_url != blank -%}
      <a class="social-icon-btn" href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        <span>Facebook</span>
      </a>
    {%- endif -%}
    {%- if section.settings.instagram_url != blank -%}
      <a class="social-icon-btn social-icon-instagram" href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        <span>Instagram</span>
      </a>
    {%- endif -%}
    {%- if section.settings.youtube_url != blank -%}
      <a class="social-icon-btn social-icon-youtube" href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/></svg>
        <span>YouTube</span>
      </a>
    {%- endif -%}
    {%- if section.settings.pinterest_url != blank -%}
      <a class="social-icon-btn social-icon-pinterest" href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        <span>Pinterest</span>
      </a>
    {%- endif -%}
    {%- if section.settings.twitter_url != blank -%}
      <a class="social-icon-btn" href="{{ section.settings.twitter_url }}" target="_blank" rel="noopener" aria-label="X / Twitter">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
        <span>X / Twitter</span>
      </a>
    {%- endif -%}
    {%- if section.settings.tiktok_url != blank -%}
      <a class="social-icon-btn social-icon-tiktok" href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.73a4.85 4.85 0 0 1-1.01-.04z"/></svg>
        <span>TikTok</span>
      </a>
    {%- endif -%}
  </div>
</div>

<style>
.social-section { background: linear-gradient(135deg, var(--purple-pale), var(--purple-soft)); }
.social-icons-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  max-width: 800px;
  margin: 0 auto;
}
.social-icon-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 24px;
  border-radius: 50px;
  background: var(--white);
  border: 1.5px solid var(--border);
  color: var(--text-mid);
  text-decoration: none;
  font-size: 0.88rem;
  font-weight: 700;
  transition: all 0.2s;
  box-shadow: var(--shadow-sm);
}
.social-icon-btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}
.social-icon-btn svg { flex-shrink: 0; }

/* Platform brand colors on hover */
.social-icon-btn:hover                 { border-color: #1877F2; color: #1877F2; } /* Facebook default */
.social-icon-instagram:hover           { border-color: #E1306C; color: #E1306C; }
.social-icon-youtube:hover             { border-color: #FF0000; color: #FF0000; }
.social-icon-pinterest:hover           { border-color: #E60023; color: #E60023; }
.social-icon-tiktok:hover              { border-color: #000; color: #000; }

@media (max-width: 600px) {
  .social-icon-btn { padding: 12px 18px; font-size: 0.82rem; }
  .social-icons-row { gap: 10px; }
}
</style>

{% schema %}
{
  "name": "Social Strip",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Follow Our Ministry" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stay Connected" },
    { "type": "textarea", "id": "subtext", "label": "Subtext (optional)", "default": "Follow us for worship inspiration, behind-the-scenes, and new arrivals" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" },
    { "type": "url", "id": "pinterest_url", "label": "Pinterest URL" },
    { "type": "url", "id": "twitter_url", "label": "Twitter / X URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" }
  ],
  "presets": [{ "name": "Social Strip" }]
}
{% endschema %}
