<footer>
  <div class="footer-inner">
    <div class="footer-brand-col">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | img_url: '280x' }}" alt="{{ shop.name }}" style="height:64px;width:auto;">
      {%- else -%}
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="height:64px;width:auto;">
      {%- endif -%}
      <p class="footer-tagline">Praise &amp; Worship Apparel</p>

      {%- comment -%} Payment icons — hardcoded Shopify CDN SVGs {%- endcomment -%}
      <div class="footer-payment-row" style="gap:6px;margin-bottom:18px;display:flex;flex-wrap:wrap;align-items:center;">
        {%- assign payment_types = 'visa,master,paypal,american_express,discover,shopify_pay' | split: ',' -%}
        {%- for type in payment_types -%}
          <img src="{{ type | payment_type_img_url }}"
               alt="{{ type | replace: '_', ' ' | capitalize }}"
               style="height:28px;width:auto;border-radius:4px;background:#fff;padding:2px 5px;">
        {%- endfor -%}
      </div>

      <div class="footer-socials">
        {%- if section.settings.facebook_url != blank -%}
          <a class="footer-social-btn" href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" title="Facebook">f</a>
        {%- else -%}
          <a class="footer-social-btn" href="https://facebook.com/rejoicedanceministry" target="_blank" rel="noopener" title="Facebook">f</a>
        {%- endif -%}
        {%- if section.settings.twitter_url != blank -%}
          <a class="footer-social-btn" href="{{ section.settings.twitter_url }}" target="_blank" rel="noopener" title="Twitter">𝕏</a>
        {%- else -%}
          <a class="footer-social-btn" href="https://twitter.com/rejoicedanceministry" target="_blank" rel="noopener" title="Twitter">𝕏</a>
        {%- endif -%}
        {%- if section.settings.pinterest_url != blank -%}
          <a class="footer-social-btn" href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener" title="Pinterest">P</a>
        {%- else -%}
          <a class="footer-social-btn" href="https://pinterest.com/rejoicedanceministry" target="_blank" rel="noopener" title="Pinterest">P</a>
        {%- endif -%}
        {%- if section.settings.instagram_url != blank -%}
          <a class="footer-social-btn" href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" title="Instagram">📷</a>
        {%- else -%}
          <a class="footer-social-btn" href="https://instagram.com/rejoicedanceministry" target="_blank" rel="noopener" title="Instagram">📷</a>
        {%- endif -%}
      </div>
    </div>

    <div class="footer-col">
      <h4>Information</h4>
      <ul>
        <li><a href="{{ pages['about'].url }}">About Rejoice</a></li>
        <li><a href="{{ pages['delivery-information'].url }}">Delivery Information</a></li>
        <li><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>
        <li><a href="{{ shop.terms_of_service.url }}">Terms &amp; Conditions</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Store</h4>
      <ul>
        <li><a href="{{ routes.collections_url }}">Online Store</a></li>
        <li><a href="{{ routes.cart_url }}">My Cart</a></li>
        <li><a href="{{ routes.account_url }}">My Account</a></li>
      </ul>
    </div>

    <div class="footer-col footer-contact-col">
      <h4>Contact Us</h4>
      <ul>
        <li><a href="{{ pages['contact'].url }}">Contact Us</a></li>
        <li>P 305.558.2212</li>
        <li>F 305.558.2253</li>
        <li>2479 West 80 Street<br>Hialeah, Florida 33016</li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    &copy; {{ 'now' | date: '%Y' }} Rejoice Dance Ministry &middot; All Rights Reserved
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Footer logo" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "url", "id": "twitter_url", "label": "Twitter / X URL" },
    { "type": "url", "id": "pinterest_url", "label": "Pinterest URL" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" }
  ]
}
{% endschema %}
