{%- assign featured_handles = 'holy-fire-garments,angelic-heavenly-praise,dresses,ephods,anointed,angel-wings-angel-wing-shield,head-pieces,accessories' | split: ',' -%}

<div class="section" style="padding-top:0;">
  <div class="section-title fade-in">
    <span class="eyebrow">Browse by Category</span>
    <h2>Our Collections</h2>
    <div class="divider-purple"></div>
    <p>Beautifully designed praise &amp; worship garments for every ministry need</p>
  </div>

  <div class="categories-grid categories-grid-8">
    {%- for handle in featured_handles -%}
      {%- assign cat = collections[handle] -%}
      {%- if cat != blank -%}
        <a class="category-card fade-in" href="{{ cat.url }}">
          <div class="category-bg">
            {%- if cat.image -%}
              <img src="{{ cat.image | img_url: '600x600', crop: 'center' }}"
                   alt="{{ cat.image.alt | escape }}"
                   style="width:100%;height:100%;object-fit:cover;" />
            {%- else -%}
              <div class="cat-icon-wrap">
                {%- case handle -%}
                  {%- when 'holy-fire-garments' -%}
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c0 0-4 4-4 8a4 4 0 0 0 8 0c0-4-4-8-4-8z"/><path d="M8 14c-2 1-3 3-3 5h14c0-2-1-4-3-5"/><path d="M12 10c0 0-2 2-2 4"/></svg>
                  {%- when 'angelic-heavenly-praise' -%}
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 9l9 4 9-4-9-7z"/><path d="M3 9v6l9 4 9-4V9"/><path d="M12 13v9"/></svg>
                  {%- when 'dresses' -%}
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2h8M9 2 6 8l2 2-4 12h16L16 10l2-2-3-6"/><path d="M9 10h6"/></svg>
                  {%- when 'ephods' -%}
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="2" width="12" height="8" rx="1"/><path d="M6 6h12M6 10l-2 12h16L18 10"/><path d="M10 14h4"/></svg>
                  {%- when 'anointed' -%}
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2 5h5l-4 3 1.5 5L12 12l-4.5 3L9 10 5 7h5z"/></svg>
                  {%- when 'angel-wings-angel-wing-shield' -%}
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12C8 8 3 9 3 14c0 3 3 5 5 4l4-3"/><path d="M12 12c4-4 9-3 9 2 0 3-3 5-5 4l-4-3"/><path d="M12 12v8"/></svg>
                  {%- when 'head-pieces' -%}
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/><path d="M8 8c0 0-1-3 4-3s4 3 4 3"/></svg>
                  {%- when 'accessories' -%}
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L8 8H3l4 3-2 6 7-4 7 4-2-6 4-3h-5z"/></svg>
                  {%- else -%}
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- endcase -%}
              </div>
            {%- endif -%}
          </div>
          <div class="category-overlay">
            <h3>{{ cat.title }}</h3>
            <p>{{ cat.products_count }} styles</p>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Collections",
  "presets": [{ "name": "Featured Collections" }]
}
{% endschema %}
