<div class="section-full section-gray">
  <div style="max-width:1280px;margin:0 auto;">
    <div class="section-title fade-in">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <div class="divider-purple"></div>
    </div>
    <div class="products-grid">
      {%- assign featured = collections[section.settings.collection].products -%}
      {%- if featured.size > 0 -%}
        {%- for product in featured limit: section.settings.product_limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for product in collections.all.products limit: section.settings.product_limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div style="text-align:center;margin-top:50px;">
      <a class="btn-primary" href="{{ routes.all_products_collection_url }}">View All Products</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Bestsellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Products" },
    { "type": "collection", "id": "collection", "label": "Collection to feature" },
    { "type": "range", "id": "product_limit", "label": "Number of products", "min": 2, "max": 12, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
