<div class="section">
  <div class="about-grid">
    <div class="about-visual fade-in">
      <div class="about-image-main">
        {%- if section.settings.image -%}
          <img src="{{ section.settings.image | img_url: '800x600', crop: 'center' }}"
               alt="{{ section.settings.image.alt | default: 'Rejoice Dance Ministry dancers in praise garments' }}" />
        {%- else -%}
          <img src="{{ 'about-dancers.jpg' | asset_url }}"
               alt="Rejoice Dance Ministry dancers in praise garments"
               style="width:100%;height:100%;object-fit:cover;border-radius:var(--radius-lg);" />
        {%- endif -%}
      </div>
      <div class="about-stat-card">
        <div class="num">{{ section.settings.stat_number }}</div>
        <div class="label">{{ section.settings.stat_label }}</div>
      </div>
    </div>
    <div class="about-text fade-in">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body_1 }}</p>
      <p>{{ section.settings.body_2 }}</p>
      <div class="scripture">{{ section.settings.scripture }}</div>
      <a class="btn-secondary" href="{{ pages['about'].url }}">{{ section.settings.cta_label }}</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Snapshot",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "About image" },
    { "type": "text", "id": "stat_number", "label": "Stat number", "default": "25+" },
    { "type": "text", "id": "stat_label", "label": "Stat label", "default": "Years of Ministry" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Called to Dress God's People" },
    { "type": "textarea", "id": "body_1", "label": "Body paragraph 1", "default": "Rejoice Dance Ministry was founded on a sacred calling — to create garments that allow dancers to move freely and beautifully in worship, bringing glory to Jesus Christ, the King of Kings and Lord of Lords." },
    { "type": "textarea", "id": "body_2", "label": "Body paragraph 2", "default": "Rejoice counts on the creative force in which our Lord Jesus gives us in that blessed moment when we enter in the movement of the Holy Spirit, dressed in Holy Garments to give Glory and Praise to Him." },
    { "type": "text", "id": "scripture", "label": "Scripture quote", "default": "\"Praise Him with dancing and with musical instruments\" — Psalm 150:4" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Read Our Full Story" }
  ],
  "presets": [{ "name": "About Snapshot" }]
}
{% endschema %}
