<div class="page-hero">
  {% render 'breadcrumb', breadcrumb_title: 'Create Account' %}
  <h1>Create Account</h1>
  <p>Join us and track your orders with ease</p>
</div>

<div class="section" style="max-width:480px;">
  {%- if form.errors -%}
    <div style="background:#fff0f0;border:1px solid #f5c6cb;border-radius:var(--radius);padding:16px 20px;margin-bottom:24px;color:#721c24;">
      {{ form.errors | default_errors }}
    </div>
  {%- endif -%}

  {%- form 'create_customer' -%}
    <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:40px;box-shadow:var(--shadow-md);">
      <h2 style="font-family:'Cinzel',serif;color:var(--purple-dark);font-size:1.4rem;margin-bottom:28px;">Create Account</h2>

      <div class="form-row">
        <div class="form-group">
          <label>First Name</label>
          <input type="text" name="customer[first_name]" autocomplete="given-name" placeholder="Maria" />
        </div>
        <div class="form-group">
          <label>Last Name</label>
          <input type="text" name="customer[last_name]" autocomplete="family-name" placeholder="Santos" />
        </div>
      </div>

      <div class="form-group">
        <label>Email</label>
        <input type="email" name="customer[email]" autocomplete="email" placeholder="your@email.com" required />
      </div>

      <div class="form-group">
        <label>Password</label>
        <input type="password" name="customer[password]" autocomplete="new-password" placeholder="Min. 8 characters" required />
      </div>

      <button type="submit" class="btn-primary" style="width:100%;text-align:center;padding:16px;margin-top:8px;">Create Account</button>
    </div>
  {%- endform -%}

  <div style="text-align:center;margin-top:24px;">
    <p style="color:var(--text-muted);font-size:0.9rem;">Already have an account?
      <a href="{{ routes.account_login_url }}" style="color:var(--purple);font-weight:700;text-decoration:none;">Sign in →</a>
    </p>
  </div>
</div>
