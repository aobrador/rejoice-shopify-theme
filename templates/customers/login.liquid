<div class="page-hero">
  {% render 'breadcrumb', breadcrumb_title: 'Login' %}
  <h1>My Account</h1>
  <p>Welcome back — sign in to view your orders</p>
</div>

<div class="section" style="max-width:480px;">
  {%- if form.errors -%}
    <div style="background:#fff0f0;border:1px solid #f5c6cb;border-radius:var(--radius);padding:16px 20px;margin-bottom:24px;color:#721c24;">
      {{ form.errors | default_errors }}
    </div>
  {%- endif -%}

  {%- form 'customer_login' -%}
    <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:40px;box-shadow:var(--shadow-md);">
      <h2 style="font-family:'Cinzel',serif;color:var(--purple-dark);font-size:1.4rem;margin-bottom:28px;">Sign In</h2>

      <div class="form-group">
        <label>Email</label>
        <input type="email" name="customer[email]" autocomplete="email" placeholder="your@email.com" required />
      </div>

      <div class="form-group">
        <label>Password</label>
        <input type="password" name="customer[password]" autocomplete="current-password" placeholder="••••••••" required />
      </div>

      <div style="text-align:right;margin-bottom:24px;">
        <a href="{{ routes.account_recover_url }}" style="font-size:0.82rem;color:var(--purple);text-decoration:none;">Forgot password?</a>
      </div>

      <button type="submit" class="btn-primary" style="width:100%;text-align:center;padding:16px;">Sign In</button>
    </div>
  {%- endform -%}

  <div style="text-align:center;margin-top:24px;">
    <p style="color:var(--text-muted);font-size:0.9rem;">Don't have an account?
      <a href="{{ routes.account_register_url }}" style="color:var(--purple);font-weight:700;text-decoration:none;">Create one →</a>
    </p>
  </div>
</div>
