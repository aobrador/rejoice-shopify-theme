<div class="page-hero">
  {% render 'breadcrumb', breadcrumb_title: collection.title %}
  <h1>{{ collection.title }}</h1>
  {%- if collection.description != blank -%}
    <p>{{ collection.description | strip_html }}</p>
  {%- endif -%}
</div>

<div class="section">
  {%- comment -%} Filter bar — links to sub-collections or all collections {%- endcomment -%}
  <div class="filter-bar">
    <a class="filter-btn {% if collection.handle == 'all' %}active{% endif %}" href="{{ routes.all_products_collection_url }}">All</a>
    {%- for c in collections limit: 8 -%}
      <a class="filter-btn {% if c.handle == collection.handle %}active{% endif %}" href="{{ c.url }}">{{ c.title }}</a>
    {%- endfor -%}
  </div>

  <div class="products-grid">
    {%- paginate collection.products by 24 -%}
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p style="color:var(--text-muted);grid-column:1/-1;text-align:center;padding:60px 0;">
          No products in this collection yet.
        </p>
      {%- endfor -%}
    {%- endpaginate -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div style="display:flex;justify-content:center;gap:10px;margin-top:50px;flex-wrap:wrap;">
      {%- if paginate.previous -%}
        <a class="filter-btn" href="{{ paginate.previous.url }}">← Previous</a>
      {%- endif -%}
      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a class="filter-btn" href="{{ part.url }}">{{ part.title }}</a>
        {%- else -%}
          <span class="filter-btn active">{{ part.title }}</span>
        {%- endif -%}
      {%- endfor -%}
      {%- if paginate.next -%}
        <a class="filter-btn" href="{{ paginate.next.url }}">Next →</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>
