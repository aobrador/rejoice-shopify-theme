<div class="page-hero" style="padding:40px 48px 30px;">
  {% render 'breadcrumb', breadcrumb_title: product.title %}
</div>

<div class="section" style="padding-top:32px;">
  <div class="product-detail-grid">

    <!-- ══════════════════════════════════
         LEFT — Image Gallery
    ══════════════════════════════════ -->
    <div class="product-gallery">

      <!-- Main image with zoom -->
      <div class="gallery-main" id="gallery-main">
        <div class="gallery-zoom-wrap" id="zoom-wrap">
          {%- if product.images.size > 0 -%}
            <img id="main-img"
                 src="{{ product.images[0] | img_url: '1000x' }}"
                 alt="{{ product.images[0].alt | escape }}"
                 data-zoom="{{ product.images[0].src }}" />
          {%- else -%}
            <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:6rem;">🩱</div>
          {%- endif -%}
        </div>

        <!-- Prev / Next arrows -->
        {%- if product.images.size > 1 -%}
          <button class="gallery-arrow gallery-prev" onclick="galleryStep(-1)" aria-label="Previous image">&#8592;</button>
          <button class="gallery-arrow gallery-next" onclick="galleryStep(1)" aria-label="Next image">&#8594;</button>
          <div class="gallery-dots" id="gallery-dots">
            {%- for image in product.images -%}
              <span class="gallery-dot {% if forloop.first %}active{% endif %}" onclick="galleryGo({{ forloop.index0 }})"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Zoom hint -->
        <div class="zoom-hint">🔍 Hover to zoom · Click to expand</div>
      </div>

      <!-- Thumbnail strip -->
      {%- if product.images.size > 1 -%}
        <div class="gallery-thumbs" id="gallery-thumbs">
          {%- for image in product.images -%}
            <img class="gallery-thumb {% if forloop.first %}active{% endif %}"
                 src="{{ image | img_url: '160x160' }}"
                 alt="{{ image.alt | escape }}"
                 onclick="galleryGo({{ forloop.index0 }})"
                 loading="lazy" />
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- ══════════════════════════════════
         RIGHT — Product Info
    ══════════════════════════════════ -->
    <div class="product-info">
      <div class="product-category">{{ product.vendor }}</div>
      <h1 class="product-info-title">{{ product.title }}</h1>

      <!-- Price -->
      <div class="product-info-price" id="product-price">
        {%- if product.compare_at_price > product.price -%}
          <span class="price-current">{{ product.price | money }}</span>
          <span class="price-original">{{ product.compare_at_price | money }}</span>
          <span class="product-badge badge-sale" style="position:static;display:inline-block;margin-left:6px;">Sale</span>
        {%- else -%}
          <span class="price-current">{{ product.price | money }}</span>
        {%- endif -%}
      </div>

      {%- form 'product', product, id: 'product-form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="variant-id">

        <!-- ── Variant options ── -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="variant-group">
              <div class="variant-label">
                {{ option.name }}:
                <span class="variant-selected" id="opt-selected-{{ forloop.index0 }}">{{ option.values.first }}</span>
              </div>

              {%- assign opt_name_lower = option.name | downcase -%}
              {%- if opt_name_lower == 'color' or opt_name_lower == 'colour' -%}
                <!-- Color swatches -->
                <div class="swatch-row" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    {%- assign color_handle = value | handleize -%}
                    <button type="button"
                            class="color-swatch {% if forloop.first %}selected{% endif %}"
                            data-value="{{ value | escape }}"
                            data-option-index="{{ option.position | minus: 1 }}"
                            title="{{ value }}"
                            style="background: {{ color_handle }};"
                            onclick="selectOption(this, {{ option.position | minus: 1 }}, '{{ value | escape }}')">
                      <span class="swatch-label">{{ value }}</span>
                    </button>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <!-- Size / other option buttons -->
                <div class="option-row" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <button type="button"
                            class="option-btn {% if forloop.first %}selected{% endif %}"
                            data-value="{{ value | escape }}"
                            data-option-index="{{ option.position | minus: 1 }}"
                            onclick="selectOption(this, {{ option.position | minus: 1 }}, '{{ value | escape }}')">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- Quantity -->
        <div class="variant-group">
          <div class="variant-label">Quantity</div>
          <div class="qty-control">
            <button type="button" onclick="changeQty(-1)">−</button>
            <input type="number" name="quantity" value="1" min="1" id="qty-input" />
            <button type="button" onclick="changeQty(1)">+</button>
          </div>
        </div>

        <!-- Add to Cart -->
        <div id="add-to-cart-wrap">
          {%- if product.available -%}
            <button type="submit" class="btn-add btn-add-large" id="add-to-cart-btn">
              Add to Cart — <span id="btn-price">{{ product.price | money }}</span>
            </button>
          {%- else -%}
            <button type="button" class="btn-add btn-add-large" disabled style="opacity:0.5;cursor:not-allowed;">
              Sold Out
            </button>
          {%- endif -%}
        </div>

        <!-- Availability -->
        <div id="variant-availability" style="margin-top:10px;font-size:0.82rem;color:var(--text-muted);">
          {%- if product.available -%}
            ✅ In stock — ready to make
          {%- else -%}
            ❌ Currently unavailable
          {%- endif -%}
        </div>

      {%- endform -%}

      <!-- Trust badges -->
      <div class="trust-badges">
        <span>✂️ Handcrafted in Hialeah, FL</span>
        <span>🚚 Priority Mail 2–3 Days</span>
        <span>🌈 XS – 4X Available</span>
        <span>🔒 Secure Checkout</span>
      </div>

      <!-- Description -->
      {%- if product.description != blank -%}
        <div class="product-description">
          {{ product.description }}
        </div>
      {%- endif -%}

      <!-- Share -->
      <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border);">
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}"
           target="_blank" rel="noopener"
           style="font-size:0.82rem;color:var(--purple);text-decoration:none;margin-right:16px;">📘 Share</a>
        <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_image | img_url: '600x600' }}&description={{ product.title | url_encode }}"
           target="_blank" rel="noopener"
           style="font-size:0.82rem;color:var(--purple);text-decoration:none;">📌 Pin it</a>
      </div>
    </div>

  </div><!-- /product-detail-grid -->
</div>

<!-- ══════════════════════════════════════════════
     PRODUCT TABS — Description / Additional Info / Size Chart / Reviews
══════════════════════════════════════════════ -->
<div class="section" style="padding-top:0;">
  <div class="product-tabs-wrap">

    <div class="product-tab-nav" role="tablist">
      <button class="product-tab-btn active" data-tab="description" role="tab">Description</button>
      <button class="product-tab-btn" data-tab="additional" role="tab">Additional Info</button>
      <button class="product-tab-btn" data-tab="sizechart" role="tab">Size Chart</button>
      <button class="product-tab-btn" data-tab="reviews" role="tab">Reviews</button>
    </div>

    <!-- Description -->
    <div class="product-tab-panel active" id="tab-description">
      {%- if product.description != blank -%}
        <div class="product-description" style="margin-top:0;border-top:none;padding-top:0;">
          {{ product.description }}
        </div>
      {%- else -%}
        <p style="color:var(--text-muted);">No description available for this product.</p>
      {%- endif -%}
    </div>

    <!-- Additional Info -->
    <div class="product-tab-panel" id="tab-additional">
      <table style="width:100%;border-collapse:collapse;font-size:0.92rem;">
        {%- if product.variants.first.weight > 0 -%}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:12px 0;color:var(--text-muted);width:160px;font-weight:700;">Weight</td>
            <td style="padding:12px 0;color:var(--text);">{{ product.variants.first.weight }} {{ product.variants.first.weight_unit }}</td>
          </tr>
        {%- endif -%}
        {%- if product.vendor != blank -%}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:12px 0;color:var(--text-muted);font-weight:700;">Vendor</td>
            <td style="padding:12px 0;color:var(--text);">{{ product.vendor }}</td>
          </tr>
        {%- endif -%}
        {%- if product.type != blank -%}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:12px 0;color:var(--text-muted);font-weight:700;">Type</td>
            <td style="padding:12px 0;color:var(--text);">{{ product.type }}</td>
          </tr>
        {%- endif -%}
        {%- for option in product.options_with_values -%}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:12px 0;color:var(--text-muted);font-weight:700;">{{ option.name }}</td>
            <td style="padding:12px 0;color:var(--purple);">{{ option.values | join: ', ' }}</td>
          </tr>
        {%- endfor -%}
        {%- if product.tags.size > 0 -%}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:12px 0;color:var(--text-muted);font-weight:700;">Tags</td>
            <td style="padding:12px 0;color:var(--text);">{{ product.tags | join: ', ' }}</td>
          </tr>
        {%- endif -%}
        {%- if product.variants.first.sku != blank -%}
          <tr>
            <td style="padding:12px 0;color:var(--text-muted);font-weight:700;">SKU</td>
            <td style="padding:12px 0;color:var(--text);">{{ product.variants.first.sku }}</td>
          </tr>
        {%- endif -%}
      </table>
      <p style="margin-top:20px;font-size:0.82rem;color:var(--text-muted);">🧺 Hand Wash or Dry Clean Only &nbsp;·&nbsp; Made to Order in Hialeah, FL</p>
    </div>

    <!-- Size Chart -->
    <div class="product-tab-panel" id="tab-sizechart">
      <p style="margin-bottom:20px;font-size:0.9rem;color:var(--text-muted);">All measurements in inches. When between sizes, size up for freedom of movement.</p>

      <p style="font-family:'Cinzel',serif;font-weight:700;color:var(--purple-dark);margin-bottom:10px;">👗 Adult Woman</p>
      <div class="table-wrapper" style="margin-bottom:28px;">
        <table><thead><tr><th></th><th>XS</th><th>S</th><th>M</th><th>L</th><th>XL</th><th>1X</th><th>2X</th><th>3X</th><th>4X</th></tr></thead>
        <tbody>
          <tr><td><strong>Bust</strong></td><td>31–32″</td><td>33–34″</td><td>34–36″</td><td>37–39″</td><td>40–42″</td><td>42–43″</td><td>44–46″</td><td>48–50″</td><td>52–54″</td></tr>
          <tr><td><strong>Hips</strong></td><td>32–34″</td><td>35–36″</td><td>37–38″</td><td>39–42″</td><td>42–44″</td><td>44–46″</td><td>46–48″</td><td>50–52″</td><td>54–56″</td></tr>
          <tr><td><strong>Waist</strong></td><td>22–24″</td><td>25–26″</td><td>27–29″</td><td>30–32″</td><td>33–36″</td><td>37–40″</td><td>41–43″</td><td>43–45″</td><td>46–50″</td></tr>
        </tbody></table>
      </div>

      <p style="font-family:'Cinzel',serif;font-weight:700;color:var(--purple-dark);margin-bottom:10px;">👧 Kids &amp; Teen</p>
      <div class="table-wrapper" style="margin-bottom:28px;">
        <table><thead><tr><th></th><th>XS 3/4</th><th>S 5/6</th><th>M 7/8</th><th>L 10/12</th><th>XL 14/16</th></tr></thead>
        <tbody>
          <tr><td><strong>Bust</strong></td><td>20–23″</td><td>24–26″</td><td>27–29″</td><td>30–31″</td><td>32–34″</td></tr>
          <tr><td><strong>Hips</strong></td><td>22–24″</td><td>25–27″</td><td>28–30″</td><td>31–33″</td><td>34–36″</td></tr>
          <tr><td><strong>Waist</strong></td><td>19–21″</td><td>22–23″</td><td>24–25″</td><td>26–28″</td><td>27–29″</td></tr>
        </tbody></table>
      </div>

      <p style="font-family:'Cinzel',serif;font-weight:700;color:var(--purple-dark);margin-bottom:10px;">👔 Adult Men</p>
      <div class="table-wrapper">
        <table><thead><tr><th></th><th>S</th><th>M</th><th>L</th><th>XL</th><th>1X</th><th>2X</th><th>3X</th><th>4X</th></tr></thead>
        <tbody>
          <tr><td><strong>Chest</strong></td><td>24–37″</td><td>38–40″</td><td>41–43″</td><td>44–47″</td><td>48–51″</td><td>52–55″</td><td>56–58″</td><td>59–61″</td></tr>
          <tr><td><strong>Waist</strong></td><td>28–32″</td><td>33–35″</td><td>36–38″</td><td>39–42″</td><td>43–47″</td><td>48–51″</td><td>52–55″</td><td>56–59″</td></tr>
        </tbody></table>
      </div>
    </div>

    <!-- Reviews -->
    <div class="product-tab-panel" id="tab-reviews">
      <div id="shopify-product-reviews" data-id="{{ product.id }}">
        <div style="text-align:center;padding:40px 20px;">
          <div style="font-size:3rem;margin-bottom:12px;">⭐</div>
          <h3 style="font-family:'Cinzel',serif;color:var(--purple-dark);margin-bottom:8px;">No Reviews Yet</h3>
          <p style="color:var(--text-muted);margin-bottom:24px;">Be the first to share your experience with this garment!</p>
          <p style="font-size:0.82rem;color:var(--text-muted);">To enable customer reviews, install the free <strong>Shopify Product Reviews</strong> app from the Shopify App Store.</p>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- ══════════════════════════════════════════════
     YOU MAY ALSO LIKE
══════════════════════════════════════════════ -->
{%- assign related_col = product.collections | first -%}
{%- assign related_products = related_col.products -%}
{%- if related_products.size > 1 -%}
  <div class="section-full section-gray">
    <div style="max-width:1280px;margin:0 auto;">
      <div class="section-title" style="margin-bottom:40px;">
        <span class="eyebrow">From the Same Collection</span>
        <h2>You May Also Like</h2>
        <div class="divider-purple"></div>
      </div>
      <div class="products-grid">
        {%- assign shown = 0 -%}
        {%- for p in related_products -%}
          {%- unless p.id == product.id or shown >= 4 -%}
            {% render 'product-card', product: p %}
            {%- assign shown = shown | plus: 1 -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

<!-- Lightbox modal -->
<div id="img-lightbox" onclick="closeLightbox()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:9999;align-items:center;justify-content:center;cursor:zoom-out;">
  <img id="lightbox-img" src="" alt="" style="max-width:92vw;max-height:92vh;border-radius:8px;object-fit:contain;" onclick="event.stopPropagation()" />
  <button onclick="closeLightbox()" style="position:absolute;top:20px;right:28px;background:none;border:none;color:#fff;font-size:2rem;cursor:pointer;line-height:1;">&times;</button>
  <button onclick="lightboxStep(-1);event.stopPropagation()" style="position:absolute;left:20px;background:rgba(255,255,255,0.15);border:none;color:#fff;font-size:2rem;width:48px;height:48px;border-radius:50%;cursor:pointer;">&#8592;</button>
  <button onclick="lightboxStep(1);event.stopPropagation()" style="position:absolute;right:20px;background:rgba(255,255,255,0.15);border:none;color:#fff;font-size:2rem;width:48px;height:48px;border-radius:50%;cursor:pointer;">&#8594;</button>
</div>

<!-- Variant data for JS -->
<script>
  var productVariants = {{ product.variants | json }};
  var productImages   = [
    {%- for img in product.images -%}
      { src: "{{ img | img_url: '1000x' }}", zoom: "{{ img.src }}", alt: "{{ img.alt | escape }}" }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];
  var currentImg   = 0;
  var selectedOpts = [
    {%- for option in product.options_with_values -%}
      "{{ option.values.first | escape }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  /* ── Gallery navigation ── */
  // scrollToThumb: set false when called from auto-slideshow so the page never jumps
  function galleryGo(index, scrollToThumb) {
    currentImg = index;
    var img  = productImages[index];
    var mainEl = document.getElementById('main-img');
    if (mainEl && img) {
      mainEl.src = img.src;
      mainEl.dataset.zoom = img.zoom;
      mainEl.alt = img.alt;
    }
    document.querySelectorAll('.gallery-thumb').forEach((t, i) => t.classList.toggle('active', i === index));
    document.querySelectorAll('.gallery-dot').forEach((d, i)  => d.classList.toggle('active', i === index));
    // Only scroll thumbnail strip horizontally (not the whole page) — and only when user clicks
    if (scrollToThumb !== false) {
      var strip = document.getElementById('gallery-thumbs');
      var thumbs = strip ? strip.querySelectorAll('.gallery-thumb') : [];
      if (thumbs[index]) {
        thumbs[index].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
    }
  }

  function galleryStep(delta) {
    var next = (currentImg + delta + productImages.length) % productImages.length;
    galleryGo(next, false); // auto-slideshow: never scroll the page
  }

  /* ── Auto-slideshow ── */
  var autoSlide = null;
  function startAutoSlide() {
    if (productImages.length < 2) return;
    autoSlide = setInterval(function() { galleryStep(1); }, 3500);
  }
  function stopAutoSlide() {
    clearInterval(autoSlide);
  }
  startAutoSlide();
  // Pause on hover, resume on leave
  document.addEventListener('DOMContentLoaded', function() {
    var gallery = document.getElementById('gallery-main');
    if (gallery) {
      gallery.addEventListener('mouseenter', stopAutoSlide);
      gallery.addEventListener('mouseleave', startAutoSlide);
    }
  });

  /* ── Hover zoom ── */
  document.addEventListener('DOMContentLoaded', function() {
    var wrap = document.getElementById('zoom-wrap');
    var main = document.getElementById('main-img');
    if (!wrap || !main) return;

    wrap.addEventListener('mousemove', function(e) {
      var rect   = wrap.getBoundingClientRect();
      var xPct   = ((e.clientX - rect.left) / rect.width  * 100).toFixed(2);
      var yPct   = ((e.clientY - rect.top)  / rect.height * 100).toFixed(2);
      main.style.transformOrigin = xPct + '% ' + yPct + '%';
      main.style.transform = 'scale(2.2)';
      main.style.cursor = 'zoom-in';
    });
    wrap.addEventListener('mouseleave', function() {
      main.style.transform = 'scale(1)';
      main.style.cursor = 'zoom-in';
    });
    wrap.addEventListener('click', function() { openLightbox(currentImg); });
  });

  /* ── Lightbox ── */
  function openLightbox(index) {
    var lb  = document.getElementById('img-lightbox');
    var img = document.getElementById('lightbox-img');
    if (!lb || !img || !productImages[index]) return;
    img.src = productImages[index].zoom;
    img.alt = productImages[index].alt;
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    document.getElementById('img-lightbox').style.display = 'none';
    document.body.style.overflow = '';
  }
  function lightboxStep(delta) {
    currentImg = (currentImg + delta + productImages.length) % productImages.length;
    document.getElementById('lightbox-img').src = productImages[currentImg].zoom;
    galleryGo(currentImg);
  }
  document.addEventListener('keydown', function(e) {
    var lb = document.getElementById('img-lightbox');
    if (lb.style.display === 'flex') {
      if (e.key === 'Escape')      closeLightbox();
      if (e.key === 'ArrowLeft')   lightboxStep(-1);
      if (e.key === 'ArrowRight')  lightboxStep(1);
    }
  });

  /* ── Quantity ── */
  function changeQty(delta) {
    var input = document.getElementById('qty-input');
    input.value = Math.max(1, parseInt(input.value || 1) + delta);
  }

  /* ── Variant selection ── */
  function selectOption(btn, optionIndex, value) {
    // Update selected label
    var label = document.getElementById('opt-selected-' + optionIndex);
    if (label) label.textContent = value;

    // Highlight selected button
    var row = btn.closest('.option-row, .swatch-row');
    if (row) row.querySelectorAll('.option-btn, .color-swatch').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');

    // Store selection
    selectedOpts[optionIndex] = value;

    // Find matching variant
    var match = productVariants.find(function(v) {
      return v.options.every(function(opt, i) { return opt === selectedOpts[i]; });
    });

    if (match) {
      document.getElementById('variant-id').value = match.id;
      // Update price
      var fmt = function(cents) { return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ','); };
      document.getElementById('btn-price').textContent = fmt(match.price);
      var priceEl = document.getElementById('product-price');
      if (priceEl) {
        if (match.compare_at_price && match.compare_at_price > match.price) {
          priceEl.innerHTML = '<span class="price-current">' + fmt(match.price) + '</span> <span class="price-original">' + fmt(match.compare_at_price) + '</span>';
        } else {
          priceEl.innerHTML = '<span class="price-current">' + fmt(match.price) + '</span>';
        }
      }
      // Update availability
      var avail = document.getElementById('variant-availability');
      var addBtn = document.getElementById('add-to-cart-btn');
      if (avail) avail.textContent = match.available ? '✅ In stock — ready to make' : '❌ Currently unavailable';
      if (addBtn) { addBtn.disabled = !match.available; addBtn.style.opacity = match.available ? '1' : '0.5'; }

      // Swap image if variant has one
      if (match.featured_image) {
        var imgIndex = productImages.findIndex(function(img) {
          return img.src.includes(match.featured_image.id);
        });
        if (imgIndex > -1) galleryGo(imgIndex);
      }
    }
  }
</script>

<style>
/* ── Product detail layout ── */
.product-detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}

/* ── Gallery ── */
.product-gallery { position: sticky; top: 90px; }
.gallery-main {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--border);
  background: #f8f8f8;
