<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" style="scroll-behavior:smooth;">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ page_description | escape }}">
  <title>
    {%- if template == 'index' -%}
      {{ shop.name }} | Praise &amp; Worship Dance Wear
    {%- elsif template == 'product' -%}
      {{ product.title }} — {{ shop.name }}
    {%- elsif template == 'collection' -%}
      {{ collection.title }} — {{ shop.name }}
    {%- else -%}
      {{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,500;1,600&display=swap" rel="stylesheet">
  {{ 'style.css' | asset_url | stylesheet_tag }}
</head>
<body>

  {%- section 'announcement-bar' -%}
  {%- section 'header' -%}

  <main id="MainContent" style="display:block;width:100%;max-width:100%;margin:0;padding:0;">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <div class="toast" id="toast"></div>

  <!-- Cart Drawer -->
  <div class="cart-drawer-overlay" id="cart-drawer-overlay"></div>
  <div class="cart-drawer" id="cart-drawer" aria-hidden="true">
    <div class="cart-drawer-header">
      <h3 class="cart-drawer-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        Your Cart <span class="cart-drawer-count" id="drawer-item-count"></span>
      </h3>
      <button class="cart-drawer-close" id="cart-drawer-close" aria-label="Close cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="cart-drawer-body" id="cart-drawer-body">
      <div class="cart-drawer-loading" id="cart-drawer-loading">
        <div class="drawer-spinner"></div>
      </div>
    </div>
    <div class="cart-drawer-footer" id="cart-drawer-footer" style="display:none;">
      <div class="drawer-subtotal-row">
        <span class="drawer-subtotal-label">Subtotal</span>
        <span class="drawer-subtotal-amount" id="drawer-subtotal"></span>
      </div>
      <p class="drawer-shipping-note">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Shipping &amp; taxes calculated at checkout
      </p>
      <div class="drawer-footer-btns">
        <a href="/cart" class="btn-secondary drawer-view-cart-btn">View Cart</a>
        <a href="/checkout" class="btn-add drawer-checkout-btn">Checkout →</a>
      </div>
    </div>
  </div>

  <!-- Back to top -->
  <button class="back-to-top" id="back-to-top" aria-label="Back to top">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

  <!-- Quick View Modal -->
  <div class="qv-overlay" id="qv-overlay" onclick="closeQuickView()"></div>
  <div class="qv-modal" id="qv-modal" aria-hidden="true" role="dialog" aria-label="Quick view">
    <button class="qv-close" id="qv-close" onclick="closeQuickView()" aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="qv-inner" id="qv-inner">
      <div class="qv-loading">
        <div class="drawer-spinner"></div>
      </div>
    </div>
  </div>

  <!-- Inline nav search (injected into nav via JS) -->

  {{ 'main.js' | asset_url | script_tag }}
</body>
</html>
