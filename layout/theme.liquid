<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ page_description | escape }}">
  <title>
    {%- if template == 'index' -%}
      {{ shop.name }} | Praise &amp; Worship Dance Wear
    {%- elsif template == 'product' -%}
      {{ product.title }} — {{ shop.name }}
    {%- elsif template == 'collection' -%}
      {{ collection.title }} — {{ shop.name }}
    {%- else -%}
      {{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,600;1,500;1,600&display=swap" rel="stylesheet">
  {{ 'style.css' | asset_url | stylesheet_tag }}
</head>
<body>

  {%- section 'announcement-bar' -%}
  {%- section 'header' -%}

  <main id="MainContent" style="display:block;width:100%;max-width:100%;margin:0;padding:0;">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <div class="toast" id="toast"></div>

  {{ 'main.js' | asset_url | script_tag }}
</body>
</html>
