{% comment %}
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

<div class="product-card fade-in">
  <a href="{{ product.url }}" class="product-image-link">
      <div class="product-image">
        {%- if product.featured_image != blank -%}
          <img
            class="product-img-primary"
            src="{{ product.featured_image | img_url: '600x800', crop: 'top' }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="lazy"
            width="600" height="800">
          {%- if product.images.size > 1 -%}
            <img
              class="product-img-secondary"
              src="{{ product.images[1] | img_url: '600x800', crop: 'top' }}"
              alt="{{ product.images[1].alt | escape }}"
              loading="lazy"
              width="600" height="800">
          {%- endif -%}
        {%- else -%}
          <span style="font-size:3rem;color:var(--purple-light);opacity:0.4;">◆</span>
        {%- endif -%}

        {%- if product.compare_at_price > product.price -%}
          <span class="product-badge badge-sale">Sale</span>
        {%- elsif product.tags contains 'new' -%}
          <span class="product-badge badge-new">New</span>
        {%- endif -%}

        <div class="product-img-overlay">
          <button
            class="quick-view-btn"
            onclick="event.preventDefault();event.stopPropagation();openQuickView('{{ product.handle }}');"
            aria-label="Quick view {{ product.title | escape }}">
            Quick View
          </button>
        </div>
      </div>
  </a>

  <div class="product-body">
    <div class="product-category">{{ product.type }}</div>
    <a href="{{ product.url }}" class="product-name-link">
      <div class="product-name">{{ product.title }}</div>
    </a>
    <div class="product-price">
      {{ product.price | money }}
      {%- if product.compare_at_price > product.price -%}
        <span class="original">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    <div class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}'></div>

    {%- if product.available -%}
      <form action="{{ routes.cart_add_url }}" method="post" class="add-to-cart-form">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" class="btn-add">Add to Cart</button>
      </form>
    {%- else -%}
      <button class="btn-add" disabled style="opacity:0.5;cursor:not-allowed;">Sold Out</button>
    {%- endif -%}
  </div>
</div>

<style>
.product-img-primary, .product-img-secondary {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  transition: opacity 0.4s ease;
}
.product-img-secondary { opacity: 0; }
.product-card:hover .product-img-primary { opacity: 0; }
.product-card:hover .product-img-secondary { opacity: 1; }
.product-img-overlay {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  background: rgba(75, 0, 130, 0.45);
  opacity: 0;
  transition: opacity 0.3s ease;
}
.quick-view-btn {
  color: #fff;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  border: 1.5px solid rgba(255,255,255,0.8);
  padding: 9px 22px;
  border-radius: 50px;
  backdrop-filter: blur(4px);
  background: transparent;
  cursor: pointer;
  font-family: inherit;
  transition: background 0.2s, border-color 0.2s;
}
.quick-view-btn:hover {
  background: rgba(255,255,255,0.18);
  border-color: #fff;
}
.product-card:hover .product-img-overlay { opacity: 1; }
</style>
